<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)../'))" />

  <PropertyGroup>
    <NoWarn>$(NoWarn);SA1633;CS1591</NoWarn>
    <SkipAnalyzers>true</SkipAnalyzers>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <Api>false</Api>
    <DisableNETStandardCompatErrors>true</DisableNETStandardCompatErrors>

    <ArtifactsTemplateGeneratedContentDir>$(ArtifactsDir)ProjectTemplates\GeneratedContent\</ArtifactsTemplateGeneratedContentDir>
  </PropertyGroup>

  <!--
    Template projects use ProjectReferences to accomplish 2 goals:

    1. To collect the package ID and Version from the project
       for use in the template.

    2. To ensure `build.cmd -vs AI` results in the referenced
       project being included in the SDK.sln file, along with
       its transitive project references.

    These must be declared as <ProjectReference> items rather than
    using an MSBuild target to collect them from <TemplatePackageVersion>
    items, as SlnGen doesn't invoke the targets.

    By setting IncludeAssets="all" by default for all ProjectReference
    items, this prevents the assets of the project from being consumed
    by the build, and it also prevents the project's package being
    included as a package reference in the template package.

    The referenced projects also do not need to be built when the
    template package is built since none of its assets are consumed.
  -->
  <ItemDefinitionGroup>
    <ProjectReference IncludeAssets="none" BuildReference="false" />
  </ItemDefinitionGroup>

</Project>
