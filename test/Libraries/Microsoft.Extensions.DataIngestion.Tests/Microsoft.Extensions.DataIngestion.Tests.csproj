<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!--  Multidimensional arrays should not be used -->
    <NoWarn>$(NoWarn);S3967</NoWarn>
    <!--  Implement IDisposable correctly -->
    <NoWarn>$(NoWarn);CA1063</NoWarn>

    <!-- https://github.com/dotnet/efcore/issues/33472#issuecomment-2042146335 -->
    <PlatformTarget Condition="'$(TargetFrameworkIdentifier)' != '.NETCoreApp'">x64</PlatformTarget>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Libraries\Microsoft.Extensions.DataIngestion.Markdig\Microsoft.Extensions.DataIngestion.Markdig.csproj" />
    <ProjectReference Include="..\..\..\src\Libraries\Microsoft.Extensions.DataIngestion.MarkItDown\Microsoft.Extensions.DataIngestion.MarkItDown.csproj" />
    <ProjectReference Include="..\..\..\src\Libraries\Microsoft.Extensions.DataIngestion\Microsoft.Extensions.DataIngestion.csproj" />
    <ProjectReference Include="..\..\..\src\Libraries\Microsoft.Extensions.Diagnostics.Testing\Microsoft.Extensions.Diagnostics.Testing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DocumentFormat.OpenXml" />
    <PackageReference Include="Microsoft.ML.Tokenizers.Data.Cl100kBase" />
    <PackageReference Include="Microsoft.ML.Tokenizers.Data.O200kBase" />
    <PackageReference Include="CommunityToolkit.VectorData.InMemory" />
    <PackageReference Include="CommunityToolkit.VectorData.SqliteVec" />
    <!-- Lift CVE-impacted transitive dependency; remove once the direct dependency updates. -->
    <PackageReference Include="OpenTelemetry.Api" />
    <PackageReference Include="OpenTelemetry.Exporter.InMemory" />
    <!-- Override transitive dependency to fix vulnerability in 8.0.0 -->
    <PackageReference Include="System.IO.Packaging" />
  </ItemGroup>

  <ItemGroup>
    <!-- Suppress NU1903 for SQLitePCLRaw.lib.e_sqlite3, a transitive dependency of CommunityToolkit.VectorData.SqliteVec (GHSA-2m69-gcr7-jv3q). -->
    <NuGetAuditSuppress Include="https://github.com/advisories/GHSA-2m69-gcr7-jv3q" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="..\Microsoft.Extensions.AI.Abstractions.Tests\TestChatClient.cs" />
    <Compile Include="..\Microsoft.Extensions.AI.Abstractions.Tests\TestEmbeddingGenerator.cs" />
    <!-- We don't run Sqlite tests on Full Framework due to some native dependency issues -->
    <Compile Remove="Writers\SqliteVectorStoreWriterTests.cs" Condition="'$(TargetFrameworkIdentifier)' != '.NETCoreApp'" />
  </ItemGroup>

</Project>
