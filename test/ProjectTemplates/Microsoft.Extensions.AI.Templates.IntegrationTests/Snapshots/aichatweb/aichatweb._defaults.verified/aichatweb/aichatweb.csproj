<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>{00000000-0000-0000-0000-000000000000}</UserSecretsId>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Foundry Local ships native runtime assets per RID, so restore must be RID-aware for the build to resolve them. -->
    <RuntimeIdentifiers>win-x64;win-arm64;linux-x64;linux-arm64;osx-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AI.Foundry.Local" Version="{VERSION}" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="{VERSION}" />
    <PackageReference Include="Microsoft.Extensions.AI" Version="{VERSION}" />
    <PackageReference Include="Microsoft.Extensions.DataIngestion" Version="{VERSION}" />
    <PackageReference Include="Microsoft.Extensions.DataIngestion.Markdig" Version="{VERSION}" />
    <PackageReference Include="PdfPig" Version="{VERSION}" />
    <PackageReference Include="Microsoft.ML.Tokenizers.Data.Cl100kBase" Version="{VERSION}" />
    <PackageReference Include="Microsoft.ML.Tokenizers.Data.O200kBase" Version="{VERSION}" />
    <PackageReference Include="CommunityToolkit.VectorData.SqliteVec" Version="{VERSION}" />
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="{VERSION}" />
  </ItemGroup>

</Project>
